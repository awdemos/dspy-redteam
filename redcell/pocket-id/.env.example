# Fly.io secrets for Pocket ID (redcell-pocket-id app)
ENCRYPTION_KEY=

# SMTP configuration for sending login codes and notifications.
# Resend example: host=smtp.resend.com, port=587, user=resend, password=<RESEND_API_KEY>, tls=starttls
SMTP_HOST=
SMTP_PORT=
SMTP_FROM=
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=starttls
SMTP_SKIP_CERT_VERIFY=false

# GHCR credentials used by Dagger publish (CI or local)
GHCR_TOKEN=
GITHUB_USERNAME=
